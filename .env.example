# Copy to .env and fill in. Used only by the docker-compose (non-HA) path.
# On Home Assistant these values go into the add-on's Configuration tab instead.

BOT_TOKEN=123456:your-bot-token-from-BotFather
API_ID=1234567
API_HASH=your_api_hash_from_my_telegram_org

# Comma-separated numeric Telegram user ids. Leave empty for first-owner mode
# (the first person who messages the bot becomes its only user).
ALLOWED_USER_IDS=

# best = best MP4-compatible quality, hd480 = capped at 480p
DEFAULT_FORMAT=best
